# GENERATED: use this file to upload env vars to Vercel (placeholders only)
# DO NOT commit real secrets. Replace placeholders before uploading.

# Core
NODE_ENV=production
NEXT_PUBLIC_BASE_URL=https://tudominio.com
NEXT_PUBLIC_API_URL=/api

# Database (Prisma)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public

# Supabase (optional)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Admin / Auth
ADMIN_EMAIL=admin@onelike.com
ADMIN_PASSWORD=ChangeThisPassword123!
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
COOKIE_NAME=admin_token

# WhatsApp & AI
WHATSAPP_VERIFY_TOKEN=replace_verify_token
WHATSAPP_API_TOKEN=replace_whatsapp_token
WHATSAPP_PHONE_ID=replace_phone_id
WHATSAPP_GRAPH_API_VERSION=v17.0
WA_AI_SYSTEM_PROMPT=Eres un asistente de ventas para una tienda online. Responde en español y sé amable.

# AI provider credentials
# Prefer base64 for the Vertex service account JSON; alternatively set raw JSON in VERTEX_SA_JSON (not recommended)
VERTEX_SA_JSON_BASE64=BASE64_ENCODED_SERVICE_ACCOUNT_JSON
VERTEX_SA_JSON=
GEMINI_API_KEY=

GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GENAI_EMBEDDING_MODEL=text-embedding-004

# Vertex / GCP
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# PayU
PAYU_MERCHANT_ID=
PAYU_ACCOUNT_ID=
PAYU_API_KEY=
PAYU_RESPONSE_URL=https://tudominio.com/checkout/response
PAYU_CONFIRMATION_URL=https://tudominio.com/api/payu/confirmation
PAYU_CHECKOUT_URL=https://sandbox.checkout.payulatam.com/ppp-web-gateway-payu/
PAYU_TEST_MODE=1

# Wompi
WOMPI_PUBLIC_KEY=
WOMPI_INTEGRITY_SECRET=
WOMPI_EVENTS_SECRET=
WOMPI_CHECKOUT_URL=https://checkout.wompi.co/p/

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="TALLER DE MOTOS A&R <no-reply@tudominio.com>"
EMAIL_INTERNAL_TO="ventas@tudominio.com,operaciones@tudominio.com"

# Optional / monitoring
NEXT_PUBLIC_ANALYTICS_ID=
SENTRY_DSN=
