# Core
NODE_ENV=development
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=/api

# Database (Prisma)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public

# Admin/Auth
ADMIN_EMAIL=admin@onelike.com
ADMIN_PASSWORD=ChangeThisPassword123!
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
COOKIE_NAME=admin_token

# PayU
PAYU_MERCHANT_ID=
PAYU_ACCOUNT_ID=
PAYU_API_KEY=
PAYU_RESPONSE_URL=http://localhost:3000/checkout/response
PAYU_CONFIRMATION_URL=http://localhost:3000/api/payu/confirmation
PAYU_CHECKOUT_URL=https://sandbox.checkout.payulatam.com/ppp-web-gateway-payu/
PAYU_TEST_MODE=1

# Wompi
WOMPI_PUBLIC_KEY=
WOMPI_INTEGRITY_SECRET=
WOMPI_EVENTS_SECRET=
WOMPI_CHECKOUT_URL=https://checkout.wompi.co/p/

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP (Transactional emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="TALLER DE MOTOS A&R <no-reply@tudominio.com>"
EMAIL_INTERNAL_TO="ventas@tudominio.com,operaciones@tudominio.com"

# ── Vertex AI / Gemini (proveedor IA principal) ───────────────────────────────
# Opción A (recomendada): service account JSON en base64
# Genera: [Convert]::ToBase64String([IO.File]::ReadAllBytes("key.json"))
VERTEX_SA_JSON_BASE64=

# Opción B: raw JSON (menos seguro, cuidado con saltos de línea)
VERTEX_SA_JSON=

# Opción C: Gemini API key directa (sin service account)
GEMINI_API_KEY=

# GCP project y location
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1

# Modelos (valores por defecto si no se especifican)
GEMINI_MODEL=gemini-2.0-flash
GENAI_EMBEDDING_MODEL=text-embedding-004

# ── OpenAI (fallback opcional) ────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── WhatsApp Business API ─────────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_GRAPH_API_VERSION=v17.0

