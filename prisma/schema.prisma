// 🔧 Prisma Configuration
generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  extensions = [vector]
}

//
// 👕 Productos
//
model Product {
  id          String         @id @default(uuid())
  name        String
  description String
  price       Float
  currency    String
  imageUrl    String?
  images      String[]
  sku         String?        @unique
  brand       String?
  tags        String[]       @default([])
  diagramNumber String?
  category    Category
  sizes       String[]
  colors      String[]
  stock       Int
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // 🔗 Relaciones
  orderItems  OrderProduct[]
  reviews     Review[]
  comboItems  ComboItem[]
  owner       User?          @relation(fields: [ownerId], references: [id])
  ownerId     String?

  // 🛒 Mercado Libre
  meliExport      Boolean  @default(false)
  meliListingType String   @default("gold_special")  // gold_special (Clásica) | gold_pro (Premium)
  meliListing     MeliListing?

  @@index([category])
  @@index([stock])
}

model Review {
  id               Int      @id @default(autoincrement())
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId        String
  rating           Int
  comment          String?  @db.Text
  author           String
  email            String
  approved         Boolean  @default(false)
  verifiedPurchase Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([productId, approved])
}

enum Category {
  cilindros
  llantas
  frenos
  aceites_lubricantes
  filtros
  baterias
  transmision
  kit_arrastre
  suspension
  escape
  electrico
  iluminacion
  carenaje
  accesorios
  motor
  refrigeracion
}

//
// 🧾 Órdenes
//
model Order {
  id              Int           @id @default(autoincrement())
  referenceCode   String        @unique @default(uuid())
  total           Float
  currency        String        @default("COP")
  status          OrderStatus   @default(PENDING)
  transactionId   String?
  paymentMethod   PaymentMethod @default(CONTRAENTREGA)
  paymentNetwork  String?
  signature       String?
  rawResponse     Json?
  trackingNumber  String?
  trackingUrl     String?

  // 👤 Información del clienteact
  customerName    String
  customerEmail   String
  address         String
  city            String
  department      String?
  postalCode      String?
  phone           String
  cedula          String?

  // 🔗 Relación futura con usuario registrado
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])

  // 🕒 Fechas
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // 🧩 Productos en la orden
  products        OrderProduct[]

  // 🎁 Combos en la orden
  orderCombos     OrderCombo[]

  // 🛒 Mercado Libre (si la orden vino de MeLi)
  meliOrder       MeliOrder?

  // --- 👇 LÓGICA HÍBRIDA (Correcto) ---
  
  // 💸 Código de promoción aplicado
  promoCodeApplied String?

  // 🔗 Relación opcional con vendedor (por código)
  sellerId        String?
  seller          Seller?       @relation(fields: [sellerId], references: [id])
  // --- ---

  @@index([userId])
  @@index([createdAt])
  @@index([customerEmail])
  @@index([status])
}

//
// 🔁 Relación N:M entre Órdenes y Productos
//
model OrderProduct {
  id        Int      @id @default(autoincrement())
  order     Order    @relation(fields: [orderId], references: [id])
  orderId   Int
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  quantity  Int      @default(1)
  // El precio unitario exacto al momento de la compra
  unitPrice Float
}

//
// 📊 Enums
//
enum OrderStatus {
  PENDING
  APPROVED
  DECLINED
  SHIPPED
  CANCELLED
}

enum PaymentMethod {
  CONTRAENTREGA
  PAYU
  WOMPI
  MERCADO_LIBRE
}

//
// 👤 Usuarios (registro futuro)
//
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(VENDEDOR)
  name      String?
  phone     String?
  // Dirección de envío guardada
  address    String?
  city       String?
  department String?
  postalCode String?
  cedula     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Recuperación de contraseña
  passwordResetToken   String?
  passwordResetExpires DateTime?

  // 🔗 Relaciones
  orders    Order[]
  products  Product[]
  seller    Seller? // Relación 1:1 con Seller (opcional)
}

enum Role {
  SUPERADMIN
  ADMIN
  VENDEDOR
  CUSTOMER
}

//
// 🧾 Vendedores (identificados por código)
// ¡Este modelo es esencial para tu lógica!
//
model Seller {
  id      String   @id @default(cuid())
  name    String
  code    String   @unique // El código que ingresará el vendedor
  orders  Order[]

  // 🔗 Relación 1:1 futura con usuario registrado
  userId  String?  @unique
  user    User?    @relation(fields: [userId], references: [id])
}

//
// 🎁 Promociones (códigos de descuento válidos)
// ¡Este modelo también es esencial!
//
model Promotion {
  id               String    @id @default(cuid())
  code             String    @unique // El código que ingresará el cliente
  discount         Float
  description      String
  isActive         Boolean   @default(true)
  expiresAt        DateTime?
  // Targeting: "ALL" | "CATEGORY" | "PRODUCT"
  appliesTo        String    @default("ALL")
  targetCategories String[]  @default([])
  targetProductIds String[]  @default([])
}

//
// 🎁 COMBOS — Paquetes de productos con regalo sorpresa
//

model Combo {
  id            String      @id @default(cuid())
  name          String
  slug          String      @unique
  description   String      @db.Text
  /// Precio del combo (ya con descuento aplicado)
  price         Float
  /// Suma de precios individuales — se muestra tachado para mostrar el ahorro
  originalPrice Float
  currency      String      @default("COP")
  imageUrl      String?
  isActive      Boolean     @default(true)
  isFeatured    Boolean     @default(false)
  stock         Int         @default(0)
  soldCount     Int         @default(0)
  /// Etiqueta visible en la card: "Más vendido", "Nuevo", "Recomendado"…
  badge         String?
  /// Si se establece, el combo expira en esa fecha (para ofertas temporales)
  expiresAt     DateTime?

  items         ComboItem[]
  surpriseGift  SurpriseGift?
  orderCombos   OrderCombo[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([isActive, isFeatured])
  @@index([slug])
}

model ComboItem {
  id        Int     @id @default(autoincrement())
  combo     Combo   @relation(fields: [comboId], references: [id], onDelete: Cascade)
  comboId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  quantity  Int     @default(1)
}

/// El regalo sorpresa se asocia 1:1 a un combo.
/// La descripción pública solo muestra un "hint"; el nombre real se revela
/// únicamente en el correo de confirmación de pedido.
model SurpriseGift {
  id        Int    @id @default(autoincrement())
  combo     Combo  @relation(fields: [comboId], references: [id], onDelete: Cascade)
  comboId   String @unique
  /// Pista pública, ej: "para proteger tu equipo" (NO revela el regalo)
  hint      String?
  /// Nombre real del regalo — solo visible en el email de confirmación
  giftName  String
  /// Valor aproximado en COP — opcional, para mostrar el ahorro total
  giftValue Float?
}

/// Registra qué combos se compraron en una orden (para historial y analítica).
/// Los productos del combo también se guardan en OrderProduct de forma normal.
model OrderCombo {
  id        Int    @id @default(autoincrement())
  order     Order  @relation(fields: [orderId], references: [id])
  orderId   Int
  combo     Combo  @relation(fields: [comboId], references: [id])
  comboId   String
  quantity  Int    @default(1)
  unitPrice Float  // Precio al momento de la compra
}

// --- CHAT / AI / EMBEDDINGS ---
model ChatSession {
  id        Int          @id @default(autoincrement())
  userId    String?
  phone     String?      // WhatsApp wa_id
  createdAt DateTime     @default(now())
  messages  ChatMessage[]
}

model ChatMessage {
  id         Int       @id @default(autoincrement())
  session    ChatSession @relation(fields: [sessionId], references: [id])
  sessionId  Int
  role       String
  content    String    @db.Text
  metadata   Json?
  createdAt  DateTime  @default(now())
}

model Embedding {
  id         Int      @id @default(autoincrement())
  model      String
  // Usar pgvector para poder aprovechar funciones de similitud (ajusta la dimensión si usas otro modelo)
  vector     Unsupported("vector(768)")
  sourceType String?  // e.g., 'product' | 'chat'
  sourceId   String?
  text       String   @db.Text
  createdAt  DateTime @default(now())
}

model Job {
  id         Int      @id @default(autoincrement())
  type       String
  payload    Json
  status     JobStatus @default(PENDING)
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())
  processedAt DateTime?
}

enum JobStatus {
  PENDING
  PROCESSING
  FAILED
  COMPLETED
}

//
// 🔐 Registro de auditoría de seguridad
//
model AuditLog {
  id          Int       @id @default(autoincrement())
  timestamp   DateTime  @default(now())
  action      String    // e.g. ACCESS_DENIED, SENSITIVE_ACTION, LOGIN_FAILED
  path        String?
  method      String?
  actorId     String?
  actorEmail  String?
  actorRole   String?
  reason      String?
  ip          String?
  userAgent   String?

  @@index([timestamp])
  @@index([actorEmail])
  @@index([action])
}

model SecurityAuditLog {
  id         Int      @id @default(autoincrement())
  action     String
  path       String
  method     String
  actorId    String?
  actorEmail String?
  actorRole  String?
  reason     String?
  ip         String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())
}

//
// ⚙️ Configuración global de la tienda (singleton, id = 1)
//
model StoreSettings {
  id            Int      @id @default(1)
  shippingRules Json
  updatedAt     DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────
// 🛒 MERCADO LIBRE INTEGRATION
// ─────────────────────────────────────────────────────────────────

/// OAuth tokens for the connected MeLi seller account.
/// Only one row ever exists (singleton, id = 1).
model MeliToken {
  id           Int      @id @default(1)
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime          // When access_token expires (6 h from issue)
  meliUserId   String            // Numeric MeLi user ID
  nickname     String?           // Seller nickname shown in admin
  siteId       String   @default("MCO")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Global configuration for the MeLi channel.
/// Only one row ever exists (singleton, id = 1).
model MeliConfig {
  id                 Int      @id @default(1)
  /// Extra seller margin (%) added on top of MeLi's own commission.
  /// Set to 0 to only recover MeLi's fee. MeLi rates are hard-coded per listing type.
  extraMarginPercent Float    @default(0)
  fixedCostCOP       Float    @default(3500) // fixed fee per sale in COP (packaging, etc.)
  defaultListingType String   @default("gold_special")
  /// Free installments (cuotas sin interés): 3 = default, 6 = cuotas extra
  freeInstallments   Int      @default(3)
  /// JSON map: local Category enum value → MeLi category_id string
  /// e.g. { "frenos": "MCO1747", "llantas": "MCO9145" }
  categoryMap        Json     @default("{}")
  updatedAt          DateTime @updatedAt
}

/// Tracks each product published on Mercado Libre.
model MeliListing {
  id         Int      @id @default(autoincrement())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String   @unique
  meliItemId String   @unique       // e.g. "MCO1234567890"
  status     MeliListingStatus @default(ACTIVE)
  meliPrice  Float               // Last price sent to MeLi (after markup)
  lastSyncAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([meliItemId])
}

enum MeliListingStatus {
  ACTIVE
  PAUSED
  CLOSED
  UNDER_REVIEW
  ERROR
}

/// Orders that originated from Mercado Libre.
/// Linked to the canonical Order row once processed.
model MeliOrder {
  id           Int      @id @default(autoincrement())
  meliOrderId  String   @unique     // MeLi numeric order ID (as string)
  order        Order?   @relation(fields: [orderId], references: [id])
  orderId      Int?     @unique
  rawPayload   Json                 // Full order payload from MeLi API
  status       String               // MeLi order status
  shipmentId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([meliOrderId])
}