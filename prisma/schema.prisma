// 🔧 Prisma Configuration
generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  extensions = [vector]
}

//
// 👕 Productos
//
model Product {
  id          String         @id @default(uuid())
  name        String
  description String
  price       Float
  currency    String
  imageUrl    String?
  images      String[]
  sku         String?        @unique
  tags        String[]       @default([])
  diagramNumber String?
  category    Category
  sizes       String[]
  colors      String[]
  stock       Int
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // 🔗 Relaciones
  orderItems OrderProduct[]
  owner      User?          @relation(fields: [ownerId], references: [id])
  ownerId     String?
}

enum Category {
  cilindros
  llantas
  frenos
  aceites_lubricantes
  filtros
  baterias
  transmision
  kit_arrastre
  suspension
  escape
  electrico
  iluminacion
  carenaje
  accesorios
}

//
// 🧾 Órdenes
//
model Order {
  id              Int           @id @default(autoincrement())
  referenceCode   String        @unique @default(uuid())
  total           Float
  currency        String        @default("COP")
  status          OrderStatus   @default(PENDING)
  transactionId   String?
  paymentMethod   PaymentMethod @default(CONTRAENTREGA)
  paymentNetwork  String?
  signature       String?
  rawResponse     Json?

  // 👤 Información del clienteact
  customerName    String
  customerEmail   String
  address         String
  city            String
  department      String?
  postalCode      String?
  phone           String
  cedula          String?

  // 🔗 Relación futura con usuario registrado
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])

  // 🕒 Fechas
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // 🧩 Productos en la orden
  products        OrderProduct[]

  // --- 👇 LÓGICA HÍBRIDA (Correcto) ---
  
  // 💸 Código de promoción aplicado
  promoCodeApplied String?

  // 🔗 Relación opcional con vendedor (por código)
  sellerId        String?
  seller          Seller?       @relation(fields: [sellerId], references: [id])
  // --- ---
}

//
// 🔁 Relación N:M entre Órdenes y Productos
//
model OrderProduct {
  id        Int      @id @default(autoincrement())
  order     Order    @relation(fields: [orderId], references: [id])
  orderId   Int
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  quantity  Int      @default(1)
  // El precio unitario exacto al momento de la compra
  unitPrice Float
}

//
// 📊 Enums
//
enum OrderStatus {
  PENDING
  APPROVED
  DECLINED
  SHIPPED
  CANCELLED
}

enum PaymentMethod {
  CONTRAENTREGA
  PAYU
  WOMPI
}

//
// 👤 Usuarios (registro futuro)
//
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(VENDEDOR)
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 🔗 Relaciones
  orders    Order[]
  products  Product[]
  seller    Seller? // Relación 1:1 con Seller (opcional)
}

enum Role {
  SUPERADMIN
  ADMIN
  VENDEDOR
}

//
// 🧾 Vendedores (identificados por código)
// ¡Este modelo es esencial para tu lógica!
//
model Seller {
  id      String   @id @default(cuid())
  name    String
  code    String   @unique // El código que ingresará el vendedor
  orders  Order[]

  // 🔗 Relación 1:1 futura con usuario registrado
  userId  String?  @unique
  user    User?    @relation(fields: [userId], references: [id])
}

//
// 🎁 Promociones (códigos de descuento válidos)
// ¡Este modelo también es esencial!
//
model Promotion {
  id          String    @id @default(cuid())
  code        String    @unique // El código que ingresará el cliente
  discount    Float
  description String
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
}

// --- CHAT / AI / EMBEDDINGS ---
model ChatSession {
  id        Int          @id @default(autoincrement())
  userId    String?
  phone     String?      // WhatsApp wa_id
  createdAt DateTime     @default(now())
  messages  ChatMessage[]
}

model ChatMessage {
  id         Int       @id @default(autoincrement())
  session    ChatSession @relation(fields: [sessionId], references: [id])
  sessionId  Int
  role       String
  content    String    @db.Text
  metadata   Json?
  createdAt  DateTime  @default(now())
}

model Embedding {
  id         Int      @id @default(autoincrement())
  model      String
  // Usar pgvector para poder aprovechar funciones de similitud (ajusta la dimensión si usas otro modelo)
  vector     Unsupported("vector(768)")
  sourceType String?  // e.g., 'product' | 'chat'
  sourceId   String?
  text       String   @db.Text
  createdAt  DateTime @default(now())
}

model Job {
  id         Int      @id @default(autoincrement())
  type       String
  payload    Json
  status     JobStatus @default(PENDING)
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())
  processedAt DateTime?
}

enum JobStatus {
  PENDING
  PROCESSING
  FAILED
  COMPLETED
}

model SecurityAuditLog {
  id         Int      @id @default(autoincrement())
  action     String
  path       String
  method     String
  actorId    String?
  actorEmail String?
  actorRole  String?
  reason     String?
  ip         String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())
}